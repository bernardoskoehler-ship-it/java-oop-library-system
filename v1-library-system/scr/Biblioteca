public class Biblioteca {

    static Livro[] lista = {
          new Livro("Harry Poter"),
          new Livro("50 tons de cinza"),
          new Livro("JoJo")
    };

    void mostrarLista() {
        for(Livro p : lista) {
            System.out.println("Nome do livro: " +p.getNome() +" | Disponivel: " +p.getDisponivel());
        }
    }
    void mostarLivro(int i) {
        System.out.println("Livro: " +lista[i].getNome());
        if(!lista[i].getDisponivel()) {
            System.out.println("Alugado por: " +lista[i].getNomeDono());
            return;
        }
        System.out.println("Esta disponivel!");
    }
}
